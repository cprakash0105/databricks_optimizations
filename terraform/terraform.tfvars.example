# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git

aws_region       = "us-east-1"
databricks_host  = "https://your-workspace.cloud.databricks.com"
databricks_token = "<your-databricks-pat>"

environment  = "dev"
project_name = "ecommerce-optimizations"

cluster_autotermination_minutes = 30
cluster_num_workers             = 2

data_engineers = [
  "engineer1@company.com",
  "engineer2@company.com"
]

data_analysts = [
  "analyst1@company.com",
  "analyst2@company.com"
]
